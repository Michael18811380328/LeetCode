    "@babel/preset-env": "^7.11.5",
    "@babel/runtime": "^7.29.2",
    "@babel/traverse": "^7.23.2",
    "@eslint/js": "^9.11.0",
    "@types/jest": "^26.0.15",
    "@types/node": "^14.11.2",
    "babel-jest": "^29.7.0",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "29.7.0",
    "prettier": "^3.2.5",
    "regenerator-runtime": "^0.13.3",
